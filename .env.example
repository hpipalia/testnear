# TestNear Environment Configuration
# Copy this to .env locally — NEVER commit .env to Git

# Server
PORT=3000
NODE_ENV=production

# CORS — set to your actual Render domain after deploy
ALLOWED_ORIGINS=https://your-app-name.onrender.com

# Admin token for /api/cache/clear — use a strong random string
ADMIN_TOKEN=change-me-to-a-strong-random-token

# Optional: Twilio (for real SMS reminders)
# TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH=your_auth_token
# TWILIO_FROM=+14045550123

# Optional: CDC NPIN API Key (contact NPIN-info@cdc.gov)
# CDC_API_KEY=

# Optional: Google Maps API Key (for geocoding)
# GOOGLE_MAPS_KEY=
